// 04_data_structures.yasl
// Demonstrates Arrays and potentially Object properties

// Array Declaration
let numbers = [1, 2, 3, 4, 5];

// Array Indexing
let first = numbers[0];
let last = numbers[4];

// Native Array Methods
numbers.push(6);
let length = numbers.length();

// Mixed Type Arrays (if supported)
let mixed = [1, "two", true, null];

// Looping through arrays (using standard for loop)
let sum = 0;
for (let i = 0; i < numbers.length(); i++) {
    sum = sum + numbers[i];
}
